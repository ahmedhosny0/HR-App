@{
    ViewData["Title"] = "المساعد الذكي للمبيعات";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-md-11">

            <!-- كارت الواجهة الرئيسي بتصميم مودرن -->
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-dark text-white text-center py-4" style="background: linear-gradient(135deg, #212529 0%, #343a40 100%);">
                    <h4 class="mb-0 fw-bold">
                        <i class="bi bi-lightning-charge-fill text-warning me-2"></i>
                        منصة استعلام المبيعات بالذكاء الاصطناعي (Local Ollama)
                    </h4>
                    <p class="text-muted small mb-0 mt-2 text-info-light">توليد وتنفيذ استعلامات T-SQL فورياً وبأمان كامل للبيانات</p>
                </div>

                <div class="card-body p-4 bg-white">

                    <!-- خانة السؤال والإدخال -->
                    <div class="mb-4">
                        <label for="txtQuestion" class="form-label fw-bold text-secondary mb-2">
                            <i class="bi bi-chat-left-text-fill text-primary me-1"></i> اسألني أي شيء عن مبيعات الفروع والأصناف:
                        </label>
                        <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden">
                            <input type="text" id="txtQuestion" class="form-control border-end-0 fw-semibold"
                                   placeholder="مثال: ما هو الفرع الأعلى مبيعات خلال الشهر الحالي؟" style="font-size: 1.05rem;" />
                            <button class="btn btn-primary px-4 fw-bold" type="button" id="btnAsk" style="min-width: 160px;">
                                <span id="spinner" class="spinner-border spinner-border-sm d-none me-2" role="status"></span>
                                <i class="bi bi-cpu-fill me-1" id="searchIcon"></i>
                                <span id="btnText">تحليل السؤال</span>
                            </button>
                        </div>
                    </div>

                    <!-- أزرار الاستعلام السريع الاحترافية (Quick Suggestion Chips) -->
                    <div class="mb-4">
                        <span class="text-muted small d-block mb-2 fw-bold"><i class="bi bi-lightbulb text-warning"></i> مقترحات سريعة يمكنك تجربتها:</span>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill quick-chip">كم إجمالي مبيعات فرع زايد اليوم؟</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill quick-chip">أعلى 3 أصناف مبيعات من حيث الكمية</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill quick-chip">من هو المورد الأكثر مبيعاً الشهر الماضي؟</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill quick-chip">قارن مبيعات فروع المنطقة الجغرافية الشمالية</button>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25 my-4" />

                    <!-- منطقة عرض النتائج الذكية -->
                    <div id="resultContainer" class="d-none animate__animated animate__fadeIn">

                        <!-- كارت عرض القيمة المستخرجة من الداتابيز -->
                        <div class="card border-0 bg-light rounded-3 p-4 mb-3 position-relative overflow-hidden" style="border-right: 5px solid #198754 !important;">
                            <div class="position-absolute end-0 top-0 opacity-10 p-3">
                                <i class="bi bi-database-check" style="font-size: 5rem;"></i>
                            </div>
                            <h6 class="fw-bold text-success mb-3">
                                <i class="bi bi-clipboard-data-fill me-1"></i> النتيجة المستخرجة من قاعدة البيانات:
                            </h6>
                            <div class="p-3 bg-white rounded-3 shadow-sm border">
                                <h3 id="lblResult" class="fw-bold text-dark mb-0 text-center text-md-start" style="line-height: 1.6; font-size: 1.6rem;">--</h3>
                            </div>
                        </div>

                        <!-- قسم فحص ومراجعة كود الـ SQL المولد -->
                        <div class="mt-3">
                            <button class="btn btn-sm btn-link text-decoration-none text-muted fw-bold p-0" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSql">
                                <i class="bi bi-code-slash me-1"></i> عرض كود الـ T-SQL المولد بواسطة Llama 3 (للمطورين)
                            </button>

                            <div class="collapse mt-2" id="collapseSql">
                                <div class="card card-body bg-dark text-success font-monospace p-3 rounded-3 shadow-inner border-0 position-relative" style="direction: ltr; min-height: 50px;">
                                    <button class="btn btn-sm btn-outline-light position-absolute end-0 top-0 m-2 py-0 px-2" style="font-size: 0.75rem;" onclick="copySqlToClipboard()">
                                        <i class="bi bi-files"></i> نسخ الكود
                                    </button>
                                    <span id="codeSql" style="white-space: pre-wrap; font-size: 0.95rem; font-family: 'Consolas', monospace;"></span>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {

            // 1. معالجة النقر على زر اسأل الرئيسي
            $("#btnAsk").click(function () {
                var questionText = $("#txtQuestion").val().trim();

                if (questionText === "") {
                    Swal.fire({
                        icon: 'warning',
                        title: 'حقل فارغ',
                        text: 'برجاء كتابة سؤالك أو اختيار أحد المقترحات السريعة!',
                        confirmButtonText: 'مفهوم'
                    });
                    return;
                }

                // تشغيل حالة التحميل والـ Spinner المتطور
                $("#spinner").removeClass("d-none");
                $("#searchIcon").addClass("d-none");
                $("#btnText").text("جاري المعالجة...");
                $("#btnAsk").prop("disabled", true);
                $("#resultContainer").addClass("d-none");

                // إرسال طلب AJAX للـ Controller للاتصال بـ Ollama وتنفيذ الـ SQL
                $.ajax({
                    url: '/AiAssistant/AskAi',
                    type: 'POST',
                    data: { question: questionText },
                    success: function (response) {
                        // إيقاف الـ Spinner وإعادة الزر لطبيعته
                        $("#spinner").addClass("d-none");
                        $("#searchIcon").removeClass("d-none");
                        $("#btnText").text("تحليل السؤال");
                        $("#btnAsk").prop("disabled", false);

                        if (response.errorMessage) {
                            Swal.fire({
                                icon: 'error',
                                title: 'تنبيه أمني أو برمجي',
                                text: response.errorMessage,
                                confirmButtonText: 'حسناً'
                            });
                        } else {
                            // حقن وعرض النتائج في الواجهة بسلاسة
                            $("#lblResult").text(response.resultValue);
                            $("#codeSql").text(response.sqlGenerated);
                            $("#resultContainer").removeClass("d-none");

                            // اختيار النص المكتوب تلقائياً لتسهيل التعديل أو الكتابة الفورية مجدداً
                            $("#txtQuestion").focus().select();
                        }
                    },
                    error: function () {
                        // معالجة انهيار السيرفر أو انقطاع الخدمة المحلية
                        $("#spinner").addClass("d-none");
                        $("#searchIcon").removeClass("d-none");
                        $("#btnText").text("تحليل السؤال");
                        $("#btnAsk").prop("disabled", false);

                        Swal.fire({
                            icon: 'error',
                            title: 'خطأ في الاتصال المحلي',
                            text: 'تعذر الوصول إلى خادم الذكاء الاصطناعي المحلي. تأكد من أن خدمة Ollama تعمل في الخلفية.'
                        });
                    }
                });
            });

            // 2. تفعيل خاصية النقر على الـ Quick Chips المقترحة لتسريع تجربة المستخدم
            $(".quick-chip").click(function () {
                var suggestedText = $(this).text().trim();
                $("#txtQuestion").val(suggestedText);
                $("#btnAsk").click(); // تنفيذ البحث فوراً عند الضغط على الشريحة
            });

            // 3. دعم تنفيذ الطلب بمجرد ضغط زر Enter داخل صندوق النص
            $("#txtQuestion").keypress(function (e) {
                if (e.which == 13) {
                    $("#btnAsk").click();
                }
            });
        });

        // 4. دالة مساعدة لنسخ كود الـ SQL المتولد إلى الحافظة بلمسة واحدة
        function copySqlToClipboard() {
            var sqlText = $("#codeSql").text();
            if(sqlText) {
                navigator.clipboard.writeText(sqlText);
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'تم نسخ كود SQL بنجاح',
                    showConfirmButton: false,
                    timer: 1500
                });
            }
        }
    </script>
}