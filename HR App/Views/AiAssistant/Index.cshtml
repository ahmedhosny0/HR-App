@{
    ViewData["Title"] = "المساعد الذكي للمبيعات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>

    .quick-chip {
        white-space: normal;
        text-align: center;
    }

    #codeSql {
        overflow-x: auto;
        direction: ltr;
    }

    @@media (max-width: 768px) {

        .card-header h4 {
            font-size: 1.1rem;
        }

        .quick-chip {
            width: 100%;
        }

        #lblResult {
            font-size: 1.1rem;
        }

        .card-body {
            padding: 1rem;
        }
    }

</style>
<div class="container mt-4" style="direction:rtl">

    <div class="card shadow border-0">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white">

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

                <div>

                    <h4 class="mb-1">
                        <i class="fa fa-robot me-2"></i>
                        المساعد الذكي للمبيعات
                    </h4>

                    <small class="opacity-75">
                        توليد وتنفيذ استعلامات SQL فورياً وتحليل بيانات المبيعات
                    </small>

                </div>

                <div>
                    <span class="badge bg-light text-primary px-3 py-2">
                        AI Powered
                    </span>
                </div>

            </div>

        </div>

        <!-- BODY -->
        <div class="card-body">

            <!-- QUESTION -->
            <div class="mb-4">

                <label class="form-label fw-bold mb-2">

                    <i class="fa fa-comments text-primary"></i>
                    اسأل عن المبيعات أو الفروع أو الأصناف

                </label>

                <div class="row g-2">

                    <div class="col-12 col-md-9">

                        <input type="text"
                               id="txtQuestion"
                               class="form-control form-control-lg"
                               placeholder="مثال: ما هو الفرع الأعلى مبيعات اليوم؟" />

                    </div>

                    <div class="col-12 col-md-3 d-grid">

                        <button class="btn btn-primary btn-lg"
                                type="button"
                                id="btnAsk">

                            <span id="spinner"
                                  class="spinner-border spinner-border-sm d-none me-2">
                            </span>

                            <i class="fa fa-search" id="searchIcon"></i>

                            <span id="btnText">
                                تحليل السؤال
                            </span>

                        </button>

                    </div>

                </div>

            </div>

            <!-- QUICK QUESTIONS -->
            <div class="mb-4">

                <label class="form-label fw-bold mb-3">

                    <i class="fa fa-lightbulb text-warning"></i>
                    أسئلة سريعة

                </label>

                <div class="d-flex flex-wrap gap-2">

                    <button type="button"
                            class="btn btn-outline-primary quick-chip">

                        كم إجمالي مبيعات فرع زايد اليوم؟

                    </button>

                    <button type="button"
                            class="btn btn-outline-secondary quick-chip">

                        أعلى صنف مبيعاً هذا الشهر

                    </button>

                    <button type="button"
                            class="btn btn-outline-success quick-chip">

                        أقل فرع مبيعات اليوم

                    </button>

                    <button type="button"
                            class="btn btn-outline-dark quick-chip">

                        مقارنة مبيعات الفروع

                    </button>

                </div>

            </div>

            <hr />

            <!-- RESULT -->
            <div id="resultContainer" class="d-none">

                <!-- RESULT CARD -->
                <div class="card border-0 shadow-sm mb-4">

                    <div class="card-header bg-success text-white">

                        <h6 class="mb-0">

                            <i class="fa fa-database"></i>
                            نتيجة التحليل

                        </h6>

                    </div>

                    <div class="card-body">

                        <div class="bg-light rounded p-4 border">

                            <h4 id="lblResult"
                                class="fw-bold text-dark mb-0">

                                --

                            </h4>

                        </div>

                    </div>

                </div>

                <!-- SQL CARD -->
                <div class="card border-0 shadow-sm">

                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">

                        <div>

                            <i class="fa fa-code"></i>
                            كود SQL المولد

                        </div>

                        <button class="btn btn-sm btn-outline-light"
                                onclick="copySqlToClipboard()">

                            <i class="fa fa-copy"></i>
                            نسخ

                        </button>

                    </div>

                    <div class="card-body bg-dark">

                        <pre id="codeSql"
                             class="text-success mb-0"
                             style="white-space:pre-wrap;font-size:14px;font-family:Consolas;"></pre>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        $(document).ready(function () {

            // ASK BUTTON
            $("#btnAsk").click(function () {

                var questionText = $("#txtQuestion").val().trim();

                if (questionText === "") {

                    Swal.fire({

                        icon: 'warning',
                        title: 'تنبيه',
                        text: 'برجاء كتابة سؤال أولاً'

                    });

                    return;
                }

                // LOADING
                $("#spinner").removeClass("d-none");
                $("#searchIcon").addClass("d-none");

                $("#btnText").text("جاري التحليل...");

                $("#btnAsk").prop("disabled", true);

                $("#resultContainer").addClass("d-none");

                $.ajax({

                    url: '/AiAssistant/AskAi',

                    type: 'POST',

                    data: { question: questionText },

                    success: function (response) {

                        $("#spinner").addClass("d-none");

                        $("#searchIcon").removeClass("d-none");

                        $("#btnText").text("تحليل السؤال");

                        $("#btnAsk").prop("disabled", false);

                        if (response.errorMessage) {

                            Swal.fire({

                                icon: 'error',
                                title: 'خطأ',
                                text: response.errorMessage

                            });

                        }
                        else {

                            $("#lblResult").text(response.resultValue);

                            $("#codeSql").text(response.sqlGenerated);

                            $("#resultContainer").removeClass("d-none");

                        }

                    },

                    error: function () {

                        $("#spinner").addClass("d-none");

                        $("#searchIcon").removeClass("d-none");

                        $("#btnText").text("تحليل السؤال");

                        $("#btnAsk").prop("disabled", false);

                        Swal.fire({

                            icon: 'error',
                            title: 'خطأ',
                            text: 'تعذر الاتصال بالخادم'

                        });

                    }

                });

            });

            // QUICK CHIPS
            $(".quick-chip").click(function () {

                $("#txtQuestion").val($(this).text());

                $("#btnAsk").click();

            });

            // ENTER
            $("#txtQuestion").keypress(function (e) {

                if (e.which == 13) {

                    $("#btnAsk").click();

                }

            });

        });

        // COPY SQL
        function copySqlToClipboard() {

            var sqlText = $("#codeSql").text();

            navigator.clipboard.writeText(sqlText);

            Swal.fire({

                toast: true,
                position: 'top-end',
                icon: 'success',
                title: 'تم نسخ SQL',
                showConfirmButton: false,
                timer: 1500

            });

        }

    </script>
}