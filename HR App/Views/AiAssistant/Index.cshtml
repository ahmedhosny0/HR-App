@{
    ViewData["Title"] = "المساعد الذكي للمبيعات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    body {
        background: #f1f3f6;
    }

    #chatBox {
        height: 500px;
        overflow-y: auto;
        background: #ffffff;
        border-radius: 16px;
        padding: 20px;
        direction: rtl;
        scroll-behavior: smooth;
        border: 1px solid #e5e7eb;
    }

    /* ========================= */
    /* 💬 Messages */
    /* ========================= */
    .msg {
        padding: 12px 16px;
        border-radius: 16px;
        margin-bottom: 12px;
        max-width: 75%;
        word-wrap: break-word;
        line-height: 1.7;
        position: relative;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        animation: fadeInUp 0.3s ease;
    }

    /* 👤 User */
    .msg-user {
        background: linear-gradient(135deg, #0d6efd, #3d8bfd);
        color: white;
        margin-right: auto;
        border-bottom-right-radius: 4px;
    }

    /* 🤖 AI */
    .msg-ai {
        background: #f9fafb;
        color: #222;
        margin-left: auto;
        border-bottom-left-radius: 4px;
        border: 1px solid #eee;
    }

    /* 🧾 SQL */
    .msg-sql {
        background: #1e1e1e;
        color: #00ff88;
        font-family: Consolas;
        font-size: 13px;
        border-radius: 10px;
        padding: 12px;
    }

    .msg-header {
        font-size: 12px;
        opacity: .6;
        margin-bottom: 6px;
    }

    /* ========================= */
    /* ✨ Animations */
    /* ========================= */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ========================= */
    /* ⏳ Typing */
    /* ========================= */
    .dot {
        height: 6px;
        width: 6px;
        margin: 0 2px;
        background-color: #999;
        border-radius: 50%;
        display: inline-block;
        animation: blink 1.4s infinite both;
    }

        .dot:nth-child(2) {
            animation-delay: .2s;
        }

        .dot:nth-child(3) {
            animation-delay: .4s;
        }

    @@keyframes blink {
        0% {
            opacity: .2;
        }

        20% {
            opacity: 1;
        }

        100% {
            opacity: .2;
        }
    }

    /* ========================= */
    /* 📊 Table */
    /* ========================= */
    .table {
        margin-bottom: 0;
        font-size: 14px;
    }

        .table th {
            background: #212529;
            color: white;
            font-weight: 600;
        }

        .table td {
            background: #fff;
        }

    /* ========================= */
    /* 🎯 Input */
    /* ========================= */
    #txtQuestion {
        border-radius: 12px;
    }

    #btnAsk {
        border-radius: 12px;
    }

    /* ========================= */
    /* ⚡ Quick buttons */
    /* ========================= */
    .quick-chip {
        border-radius: 20px;
        padding: 6px 14px;
        font-size: 13px;
        transition: all 0.2s;
    }

        .quick-chip:hover {
            transform: translateY(-2px);
        }
    /* ========================= */
    /* 📱 Mobile تحسين */
    /* ========================= */
    @@media (max-width: 768px) {
        #chatBox

    {
        height: calc(100vh - 220px);
        padding: 12px;
        border-radius: 12px;
    }

    .msg {
        max-width: 90%;
        font-size: 14px;
        padding: 10px 12px;
    }

    .msg-sql {
        font-size: 11px;
    }

    /* input row */
    .chat-input-row {
        display: flex;
        gap: 8px;
    }

        .chat-input-row input {
            flex: 1;
            font-size: 14px;
        }

        .chat-input-row button {
            width: 55px;
            flex-shrink: 0;
        }

    /* quick buttons scroll */
    .quick-container {
        overflow-x: auto;
        flex-wrap: nowrap;
        padding-bottom: 5px;
    }

    .quick-chip {
        white-space: nowrap;
        font-size: 12px;
        padding: 5px 10px;
    }

    }
</style>

<div class="container mt-4" style="direction:rtl">

    <div class="card shadow-lg border-0" style="border-radius:16px;">

        <!-- HEADER -->
        <div class="card-header text-white"
             style="background: linear-gradient(135deg,#0d6efd,#3d8bfd); border-radius:16px 16px 0 0;">

            <h4 class="mb-1">🤖 المساعد الذكي للمبيعات</h4>
            <small style="opacity:.8">تحليل ذكي + SQL + تقارير فورية</small>

        </div>

        <div class="card-body">

            <!-- CHAT -->
            <div id="chatBox"></div>

            <!-- INPUT -->
            <div class="chat-input-row mt-3">

                <input type="text"
                       id="txtQuestion"
                       class="form-control shadow-sm"
                       placeholder="اكتب سؤالك..." />

                <button class="btn btn-primary shadow-sm" id="btnAsk">
                    <i class="fa fa-paper-plane"></i>
                </button>

            </div>

            <!-- QUICK -->
            <div class="mt-3 d-flex gap-2 quick-container">
                <button class="btn btn-outline-primary quick-chip">أعلى مبيعات اليوم</button>
                <button class="btn btn-outline-success quick-chip">أقل فرع مبيعات</button>
                <button class="btn btn-outline-dark quick-chip">قارن الفروع</button>

            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        let isTyping = false;

               function scrollDown() {
            let box = $("#chatBox")[0];
            box.scrollTo({
                top: box.scrollHeight,
                behavior: "smooth"
            });
        }
        function addMessage(type, text, id = null) {

            let css = "";

            if (type === "user") css = "msg msg-user";
            if (type === "ai") css = "msg msg-ai";
            if (type === "sql") css = "msg msg-sql";

            let elementId = id ? `id="${id}"` : "";

            $("#chatBox").append(`
                <div ${elementId} class="${css}">${text}</div>
            `);

            scrollDown();
        }

        // ✨ Typing effect
        function typeText(text, elementId, speed = 15) {

            let i = 0;
            let el = document.getElementById(elementId);
            el.innerHTML = "";

            let interval = setInterval(() => {

                el.innerHTML += text.charAt(i);
                i++;

                scrollDown();

                if (i >= text.length) {
                    clearInterval(interval);
                }

            }, speed);
        }

                        function showTyping() {

            $("#chatBox").append(`
                <div id="typingBox" class="msg msg-ai">
                    <div style="font-size:12px;opacity:.6;margin-bottom:4px;">
                        🤖 المساعد
                    </div>
                    <div>
                        يفكر
                        <span class="dot"></span>
                        <span class="dot"></span>
                        <span class="dot"></span>
                    </div>
                </div>
            `);

            scrollDown();
        }

          
        function removeTyping() {
            $("#typingBox").remove();
        }

        function sendQuestion() {

            let questionText = $("#txtQuestion").val().trim();

            if (questionText === "") {
                Swal.fire("تنبيه", "اكتب سؤال أولاً", "warning");
                return;
            }

            addMessage("user", questionText);

            $("#txtQuestion").val("");
            $("#spinner").removeClass("d-none");

            // 🔥 show typing immediately
            showTyping();

            $.ajax({
                url: '/AiAssistant/AskAi',
                type: 'POST',
                data: { question: questionText },

                success: function (response) {

                    $("#spinner").addClass("d-none");
                    removeTyping();

                    if (response.errorMessage) {
                        addMessage("ai", "❌ " + response.errorMessage);
                        return;
                    }

                    let id = "ai_" + Date.now();

                    addMessage("ai", "", id);

                        let result = response?.resultValue ?? null;

        if (typeof result === "string") {
            try {
                result = JSON.parse(result);
            } catch {
                console.log("JSON parse error");
            }
        }

        if (result && result.rows) {

            if (result.rows.length === 1 && result.columns.length === 1) {
                typeText("📊 " + result.rows[0][result.columns[0]], id);
            } else {
                renderTable(result, id);
            }

                } else {

            if (typeof result === "object") {
                renderTable(result, id);
            } else {
                typeText("📊 " + (result || "No data"), id);
            }

        }
                    // SQL improved UI
        //                    if (response.sql) {
        //     addSqlBlock(response.sql);
        // }
                },

                error: function () {
                    $("#spinner").addClass("d-none");
                    removeTyping();
                    addMessage("ai", "❌ خطأ في السيرفر");
                }
            });
        }
                function renderTable(data, elementId) {

            let html = "<div style='overflow:auto'><table class='table table-bordered table-sm'>";

            // Header
            html += "<thead><tr>";
            data.columns.forEach(col => {
                html += `<th>${col}</th>`;
            });
            html += "</tr></thead>";

            // Rows
            html += "<tbody>";
            data.rows.forEach(row => {
                html += "<tr>";
                data.columns.forEach(col => {
                    html += `<td>${row[col]}</td>`;
                });
                html += "</tr>";
            });
            html += "</tbody></table></div>";

            document.getElementById(elementId).innerHTML = html;
        }
                function addSqlBlock(sql) {

            let id = "sql_" + Date.now();

            $("#chatBox").append(`
                <div class="msg msg-sql">
                    <div style="display:flex;justify-content:space-between;">
                        <span>🧾 SQL Query</span>
                        <button onclick="copySql('${id}')" class="btn btn-sm btn-success">Copy</button>
                    </div>
                    <pre id="${id}">${sql}</pre>
                </div>
            `);

            scrollDown();
        }

        function copySql(id) {
            let text = document.getElementById(id).innerText;
            navigator.clipboard.writeText(text);
            Swal.fire("Copied", "SQL copied", "success");
        }
        $(document).ready(function () {

            $("#btnAsk").click(sendQuestion);

            $("#txtQuestion").keypress(function (e) {
                if (e.which == 13) sendQuestion();
            });

            $(".quick-chip").click(function () {
                $("#txtQuestion").val($(this).text());
                sendQuestion();
            });

        });

    </script>

}