@model HR_App.ViewModel.LeaveRequestVM
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" type="text/css" href="/css/components.css" />
<link rel="stylesheet" type="text/css" href="/css/report.css" />
<link rel="stylesheet" type="text/css" href="/css/base.css" />
<link href="/css/lib/select2.min.css" rel="stylesheet" />
<link href="/css/lib/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <div class="card shadow-sm border-0" style="border-radius: 15px;">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-calendar-plus me-2"></i> تقديم طلب إجازة جديد</h5>
        </div>

        <div class="card-body p-4">
            <form method="post" id="leaveForm">
               @*  <div class="mb-3">
                    <label class="form-label fw-bold">الموظف</label>
                    <select class="form-select select2" name="EmployeeSerial" required>
                        <option value="">-- اختر الموظف --</option>
                        @foreach (var emp in Model.Employees)
                        {
                            <option value="@emp.Value">@emp.Text</option>
                        }
                    </select>
                </div> *@

                <div class="mb-3">
                    <label class="form-label fw-bold">نوع الإجازة</label>
                    <select class="form-select select2" name="ModelTypeSerial" required>
                        <option value="">-- اختر نوع الإجازة --</option>
                        @foreach (var item in Model.LeaveTypes)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">من تاريخ</label>
                        <input type="date" class="form-control" name="FromDate" id="FromDate" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">إلى تاريخ</label>
                        <input type="date" class="form-control" name="ToDate" id="ToDate" required />
                    </div>
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                        <i class="bi bi-send-fill me-2"></i> إرسال الطلب للموافقة
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="/js/lib/jquery-3.6.0.min.js"></script>
<script src="/js/lib/select2.min.js"></script>
<script src="/js/lib/sweetalert2@11.js"></script>
<script>
    $(document).ready(function () {
        // دالة مساعدة لحساب أيام العمل (تتجاهل الجمعة والسبت)
        function getWorkDaysBetween(start, end) {
            let count = 0;
            let curDate = new Date(start.getTime());
            curDate.setDate(curDate.getDate() + 1); // نبدأ الحساب من اليوم التالي للتقديم

            while (curDate < end) {
                let dayOfWeek = curDate.getDay();
                // في JavaScript: 5 هو الجمعة، 6 هو السبت
                if (dayOfWeek !== 5 && dayOfWeek !== 6) {
                    count++;
                }
                curDate.setDate(curDate.getDate() + 1);
            }
            return count;
        }

        $('#leaveForm').on('submit', function(e) {
            let fromVal = $('#FromDate').val();
            let toVal = $('#ToDate').val();
            let typeVal = $('select[name="ModelTypeSerial"]').val();

            let fromDate = new Date(fromVal);
            let toDate = new Date(toVal);
            let now = new Date();
            now.setHours(0, 0, 0, 0); // تصفير الوقت للمقارنة بالتواريخ فقط

            // 1. فحص التواريخ المنطقية
            if (toDate < fromDate) {
                e.preventDefault();
                Swal.fire({ icon: 'error', title: 'خطأ', text: 'تاريخ النهاية قبل البداية!' });
                return;
            }

            // 2. فحص الـ 48 ساعة عمل للإجازة الاعتيادي
            if (typeVal == "1") { // تأكد أن 1 هو رقم الاعتيادي
                let workDays = getWorkDaysBetween(now, fromDate);

                if (workDays < 2) {
                    e.preventDefault();
                    Swal.fire({
                        icon: 'warning',
                        title: 'تنبيه أيام العمل',
                        text: 'الإجازة الاعتيادي تتطلب التقديم قبل الموعد بيومي عمل على الأقل (خارج أيام العطلات).'
                    });
                    return;
                }
            }
        });

        // رسائل النجاح والخطأ من السيرفر (تبقى كما هي)
        var success = '@Html.Raw(TempData["SuccessMessage"])';
        var error = '@Html.Raw(TempData["ErrorMessage"])';

        if (success) {
            Swal.fire({ icon: 'success', title: 'تم!', text: success, confirmButtonText: 'حسناً' })
                .then(() => {
                    $('#leaveForm')[0].reset();
                });
        }

        if (error) {
            Swal.fire({ icon: 'error', title: 'خطأ', text: error, confirmButtonText: 'إغلاق' });
        }
    });
</script>
