@model HR_App.ViewModel.LeaveRequestVM
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    dynamic emp = ViewBag.CurrentEmployee;
}

<link rel="stylesheet" type="text/css" href="/css/components.css" />
<link rel="stylesheet" type="text/css" href="/css/report.css" />
<link rel="stylesheet" type="text/css" href="/css/base.css" />
<link href="/css/lib/select2.min.css" rel="stylesheet" />
<link href="/css/lib/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <div class="card shadow-sm border-0" style="border-radius:15px;">

        <!-- Header -->
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-file-earmark-plus-fill me-2"></i>
                إنشاء طلب جديد
            </h5>
        </div>

        <!-- Body -->
        <div class="card-body p-4">

            <form method="post" id="requestForm" enctype="multipart/form-data">

                <div class="row g-3">
                    <div class="col-12">
                        <div class="mb-3">

                            <button type="button"
                                    id="toggleBalanceBtn"
                                    class="btn btn-outline-primary rounded-pill px-4">

                                <i class="bi bi-eye-fill me-2"></i>
                                عرض رصيد الاجازات

                            </button>

                        </div>
                        <div id="leaveBalanceCard"
                             class="card border-0 shadow-sm mt-2"
                             style="display:none; border-radius:18px; overflow:hidden;">

                            <div class="card-header text-white"
                                 style="background:linear-gradient(45deg,#0d6efd,#198754);">

                                <div class="d-flex justify-content-between align-items-center">

                                    <div>
                                        <h5 class="mb-1 fw-bold" id="empName"></h5>
                                        <small id="empCode"></small>
                                    </div>

                                    <div>
                                        <i class="bi bi-person-badge-fill fs-2"></i>
                                    </div>

                                </div>
                            </div>

                            <div class="card-body">

                                <div class="row g-3">

                                    <!-- Annual -->
                                    <div class="col-md-3">
                                        <div class="p-3 rounded bg-light text-center border">
                                            <h6 class="fw-bold text-primary">الاعتيادي</h6>

                                            <div>
                                                <small>الرصيد:</small>
                                                <strong id="annualBalance"></strong>
                                            </div>

                                            <div>
                                                <small>المستخدم:</small>
                                                <strong id="annualUsed"></strong>
                                            </div>

                                            <div>
                                                <small>المتبقي:</small>
                                                <strong id="annualRemain"></strong>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Casual -->
                                    <div class="col-md-3">
                                        <div class="p-3 rounded bg-light text-center border">
                                            <h6 class="fw-bold text-warning">العارضة</h6>

                                            <div>
                                                <small>الرصيد:</small>
                                                <strong id="casualBalance"></strong>
                                            </div>

                                            <div>
                                                <small>المستخدم:</small>
                                                <strong id="casualUsed"></strong>
                                            </div>

                                            <div>
                                                <small>المتبقي:</small>
                                                <strong id="casualRemain"></strong>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Sick -->
                                    <div class="col-md-3">
                                        <div class="p-3 rounded bg-light text-center border">
                                            <h6 class="fw-bold text-danger">المرضي</h6>

                                            <div>
                                                <small>الرصيد:</small>
                                                <strong id="sickBalance"></strong>
                                            </div>

                                            <div>
                                                <small>المستخدم:</small>
                                                <strong id="sickUsed"></strong>
                                            </div>

                                            <div>
                                                <small>المتبقي:</small>
                                                <strong id="sickRemain"></strong>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Exam -->
                                    <div class="col-md-3">
                                        <div class="p-3 rounded bg-light text-center border">
                                            <h6 class="fw-bold text-success">الامتحانات</h6>

                                            <div>
                                                <small>الرصيد:</small>
                                                <strong id="examBalance"></strong>
                                            </div>

                                            <div>
                                                <small>المستخدم:</small>
                                                <strong id="examUsed"></strong>
                                            </div>

                                            <div>
                                                <small>المتبقي:</small>
                                                <strong id="examRemain"></strong>
                                            </div>
                                        </div>
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>
                    <!-- Employee -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">
                            الموظف
                        </label>

                        <select name="EmployeeId"
                                class="form-select select2"
                                required>

                            <option value="">
                                اختر الموظف
                            </option>

                            @foreach (var e in ViewBag.Employees as List<SelectListItem>)
                            {
                                <option value="@e.Value">
                                    @e.Text
                                </option>
                            }

                        </select>
                    </div>

                    <!-- Request Type -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">
                            نوع الطلب
                        </label>

                        <select name="RequestTypeId"
                                class="form-select select2"
                                required>

                            <option value="">
                                اختر النوع
                            </option>

                            @foreach (var t in ViewBag.RequestTypes as List<SelectListItem>)
                            {
                                <option value="@t.Value">
                                    @t.Text
                                </option>
                            }

                        </select>
                    </div>

                    <!-- From Date -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">
                            من تاريخ
                        </label>

                        <input type="date"
                               name="FromDate"
                               class="form-control" />
                    </div>

                    <!-- To Date -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">
                            إلى تاريخ
                        </label>

                        <input type="date"
                               name="ToDate"
                               class="form-control" />
                    </div>
                    <div class="mb-3 form-check form-switch mt-3">

                        <input type="hidden" name="IsMultipleDays" id="IsMultipleDaysHidden" value="false" />

                        <input class="form-check-input" type="checkbox" id="isMultipleDays">

                        <label class="form-check-label fw-bold">
                            اجازة لأيام متفرقة؟
                        </label>

                    </div>
                    <!-- Multiple Days Section -->
                    <div id="multipleDaysSection" class="mt-3" style="display:none;">

                        <label class="form-label fw-bold">
                            اختر أيام الاجازة
                        </label>

                        <input type="text"
                               id="SelectedDays"
                               name="SelectedDays"
                               class="form-control"
                               placeholder="اختر أكثر من يوم" />

                        <div id="selectedDaysPreview" class="mt-2 d-flex flex-wrap gap-2"></div>

                    </div>
                    <!-- Time From -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">من وقت</label>
                        <input type="time" name="FromTime" class="form-control" />
                    </div>

                    <!-- Time To -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">إلى وقت</label>
                        <input type="time" name="ToTime" class="form-control" />
                    </div>

                    <!-- Location -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">المكان</label>
                        <input type="text"
                               name="Location"
                               class="form-control"
                               placeholder="مكان الطلب" />
                    </div>

                    <!-- Purpose -->
                    <div class="col-md-6">
                        <label class="form-label fw-bold">الغرض</label>
                        <input type="text"
                               name="Purpose"
                               class="form-control"
                               placeholder="سبب الطلب" />
                    </div>

                    <!-- Result -->
                    <div class="col-md-12">
                        <label class="form-label fw-bold">النتيجة</label>
                        <textarea name="Result"
                                  class="form-control"
                                  rows="3"
                                  placeholder="نتيجة الطلب (اختياري)"></textarea>
                    </div>

                    <!-- File Upload -->
                    <div class="col-md-12">
                        <label class="form-label fw-bold">إرفاق ملف</label>
                        <input type="file"
                               name="File"
                               class="form-control" />
                    </div> <!-- Notes -->
                    <div class="col-12">
                        <label class="form-label fw-bold">
                            ملاحظات
                        </label>

                        <textarea name="Notes"
                                  rows="4"
                                  class="form-control"
                                  placeholder="اكتب أي ملاحظات إضافية..."></textarea>
                    </div>

                </div>

                <!-- Submit -->
                <div class="d-grid mt-4">
                    <button class="btn btn-success btn-lg shadow-sm">

                        <i class="bi bi-send-fill me-2"></i>
                        إرسال الطلب

                    </button>
                </div>

            </form>

        </div>
    </div>

</div>

<script src="/js/lib/jquery-3.6.0.min.js"></script>
<script src="/js/lib/select2.min.js"></script>
<script src="/js/lib/sweetalert2@11.js"></script>

<script>
        $(document).ready(function () {

        // Flatpickr (Multiple Days)
        flatpickr("#SelectedDays", {
            mode: "multiple",
            dateFormat: "Y-m-d",
            minDate: "today",

            onChange: function (selectedDates) {

                let container = document.getElementById("selectedDaysPreview");
                container.innerHTML = "";

                selectedDates.forEach(d => {

                    let date = d.toISOString().split('T')[0];

                    let tag = document.createElement("span");
                    tag.className = "badge bg-primary p-2";
                    tag.innerText = date;

                    container.appendChild(tag);
                });
            }
        });

        // Toggle
        $('#isMultipleDays').on('change', function () {

            let isChecked = $(this).is(':checked');

            $('#IsMultipleDaysHidden').val(isChecked);

            if (isChecked) {

                $('#multipleDaysSection').show();

                $('#FromDate, #ToDate').attr('disabled', true);

            } else {

                $('#multipleDaysSection').hide();

                $('#FromDate, #ToDate').attr('disabled', false);
            }
        });

        // Validation on submit
        $('#requestForm').on('submit', function (e) {

            let isMultiple = $('#isMultipleDays').is(':checked');

             // Time validation
    let fromTime = $('input[name="FromTime"]').val();
    let toTime = $('input[name="ToTime"]').val();

    if (fromTime && toTime && toTime < fromTime) {
        e.preventDefault();

        Swal.fire({
            icon: 'error',
            title: 'خطأ',
            text: 'وقت النهاية لا يمكن أن يكون قبل البداية'
        });

        return;
    }
    if (isMultiple) {

                let selected = $('#SelectedDays').val();

                if (!selected || selected.length === 0) {

                    e.preventDefault();

                    Swal.fire({
                        icon: 'error',
                        title: 'خطأ',
                        text: 'يجب اختيار يوم واحد على الأقل'
                    });

                    return;
                }
            }
            else {

                let fromDate = $('#FromDate').val();
                let toDate = $('#ToDate').val();

                if (toDate && fromDate && toDate < fromDate) {

                    e.preventDefault();

                    Swal.fire({
                        icon: 'error',
                        title: 'خطأ',
                        text: 'تاريخ النهاية لا يمكن أن يكون قبل البداية'
                    });

                    return;
                }
            }
        });

    });
    $(document).ready(function () {

        $('.select2').select2();

        $('#requestForm').on('submit', function (e) {

            let fromDate = $('input[name="FromDate"]').val();
            let toDate = $('input[name="ToDate"]').val();

            if (fromDate && toDate) {

                if (toDate < fromDate) {

                    e.preventDefault();

                    Swal.fire({
                        icon: 'error',
                        title: 'خطأ',
                        text: 'تاريخ النهاية لا يمكن أن يكون قبل البداية'
                    });

                    return false;
                }
            }
        });

        // Success Message
        var success = '@Html.Raw(TempData["SuccessMessage"])';

        if (success) {

            Swal.fire({
                icon: 'success',
                title: 'تم بنجاح',
                html: success,
                confirmButtonText: 'حسناً'
            });

        }

        // Error Message
        var error = '@Html.Raw(TempData["ErrorMessage"])';

        if (error) {

            Swal.fire({
                icon: 'error',
                title: 'خطأ',
                html: error,
                confirmButtonText: 'إغلاق'
            });

        }

    });

</script>
<script>
    $(document).ready(function () {

        var emp = @Html.Raw(Json.Serialize(ViewBag.CurrentEmployee));

        let card = $('#leaveBalanceCard');
        let btn = $('#toggleBalanceBtn');

        let isVisible = false; // 👈 حالة العرض

        // =========================
        // INIT CURRENT USER (BUT HIDDEN)
        // =========================
        if (emp) {
            fillCard(emp);
        }

        card.hide();

        // =========================
        // TOGGLE BUTTON
        // =========================
        $('#toggleBalanceBtn').on('click', function () {

            isVisible = !isVisible;

            if (isVisible) {
                card.slideDown(200);
                btn.html(`<i class="bi bi-eye-slash-fill me-2"></i> إخفاء رصيد الاجازات`);
            } else {
                card.slideUp(200);
                btn.html(`<i class="bi bi-eye-fill me-2"></i> عرض رصيد الاجازات`);
            }
        });

        // =========================
        // EMPLOYEE CHANGE (IMPORTANT FIX)
        // =========================
        $('select[name="EmployeeId"]').on('change', function () {

            let employeeId = $(this).val();

            if (!employeeId) {
                card.hide();
                isVisible = false;
                resetCard();
                return;
            }

            $.ajax({
                url: '/Leave/GetEmployeeLeaveBalance',
                type: 'GET',
                data: { employeeId: employeeId },

                success: function (res) {

                    if (!res || !res.success) return;

                    fillCard(res);

                    // 👇 مهم جدًا: احترم حالة العرض الحالية
                    if (isVisible) {
                        card.show();
                    } else {
                        card.hide();
                    }
                }
            });

        });

        // =========================
        // FILL CARD
        // =========================
        function fillCard(res) {

            $('#empName').text(res.employeeName ?? '');
            $('#empCode').text("الكود: " + (res.employeeCode ?? ''));

            $('#annualBalance').text(res.annualBalance ?? 0);
            $('#annualUsed').text(res.annualUsed ?? 0);
            $('#annualRemain').text((res.annualBalance ?? 0) - (res.annualUsed ?? 0));

            $('#casualBalance').text(res.casualBalance ?? 0);
            $('#casualUsed').text(res.casualUsed ?? 0);
            $('#casualRemain').text((res.casualBalance ?? 0) - (res.casualUsed ?? 0));

            $('#sickBalance').text(res.sickBalance ?? 0);
            $('#sickUsed').text(res.sickUsed ?? 0);
            $('#sickRemain').text((res.sickBalance ?? 0) - (res.sickUsed ?? 0));

            $('#examBalance').text(res.examBalance ?? 0);
            $('#examUsed').text(res.examUsed ?? 0);
            $('#examRemain').text((res.examBalance ?? 0) - (res.examUsed ?? 0));
        }

        // =========================
        // RESET
        // =========================
        function resetCard() {

            $('#empName,#empCode').text('');

            $('#annualBalance,#annualUsed,#annualRemain').text('');
            $('#casualBalance,#casualUsed,#casualRemain').text('');
            $('#sickBalance,#sickUsed,#sickRemain').text('');
            $('#examBalance,#examUsed,#examRemain').text('');
        }

    });
</script>