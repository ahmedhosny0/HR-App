@model List<HR_App.ViewModel.LeaveRequestVM>

<div class="container mt-5">
    <div class="card p-4">
        <h4 class="mb-4"><i class="bi bi-person-check"></i> موافقات المدير</h4>

        <table class="table table-hover text-center align-middle">
            <thead class="table-dark">
                <tr>
                    <th>من</th>
                    <th>إلى</th>
                    <th>ملاحظات</th>
                    <th>الإجراء</th>
                </tr>
            </thead>

            <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>@item.FromDate.ToShortDateString()</td>
                    <td>@item.ToDate.ToShortDateString()</td>
                    <td>@item.Notes</td>
                    <td>
                        <button class="btn btn-success btn-sm" onclick="approve(@item.ModelSerial)">
                            <i class="bi bi-check"></i>
                        </button>

                        <button class="btn btn-danger btn-sm" onclick="reject(@item.ModelSerial)">
                            <i class="bi bi-x"></i>
                        </button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<script>
function approve(id){
    Swal.fire({
        title: 'موافقة؟',
        icon: 'question',
        showCancelButton: true
    }).then((r)=>{
        if(r.isConfirmed){
            window.location = '/Leave/ApproveByManager/' + id;
        }
    })
}

function reject(id){
    Swal.fire({
        title: 'رفض؟',
        icon: 'warning',
        showCancelButton: true
    }).then((r)=>{
        if(r.isConfirmed){
            window.location = '/Leave/RejectByManager/' + id;
        }
    })
}
</script>