@model List<HR_App.ViewModel.RequestDetailsVM>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">

    <!-- HEADER -->
    <div class="page-header mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">

        <div>
            <p class="badge bg-info fs-6 px-3 py-2">
                جميع الطلبات والتفاصيل
            </p>
        </div>

        <div>
            <span class="badge bg-dark fs-6 px-3 py-2">
                إجمالي الطلبات :
                @(Model?.Count ?? 0)
            </span>
        </div>

    </div>

    <!-- TABLE -->
    <div class="report-container">
        <div class="table-responsive">

            <table id="example" class="table-modern">

                <thead>
                    <tr>
@*                         <th>الاجراء</th>
 *@
                        <th>الحالة</th>
                        <th>الموظف</th>
@*                         <th>المدير</th>
 *@                        <th>نوع الطلب</th>
                        <th>من</th>
                        <th>إلى</th>
                        <th>تاريخ الإنشاء</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                       

                        <tr>

                            <td data-label="الحالة">

                                @{
                                    var responses = item.StatusName.Split('|');
                                }

                                @foreach (var response in responses)
                                {
                                    var text = response.Trim();

                                    string badgeClass =
                                    text.Contains("مقبول") ? "bg-success" :
                                    text.Contains("مرفوض") ? "bg-danger" :
                                    "bg-warning text-dark";

                                    <span class="badge @badgeClass px-3 py-2 me-1 mb-1">

                                        @text

                                    </span>
                                }

                            </td>
                            @*  <td>

                                <a asp-action="EditRequest"
                                   asp-route-id="@item.RequestId"
                                   class="btn btn-warning btn-sm">

                                    <i class="fas fa-edit"></i>

                                </a>

                                <button class="btn btn-danger btn-sm"
                                        onclick="deleteRequest(@item.RequestId)">

                                    <i class="fas fa-trash"></i>

                                </button>

                            </td> *@
                            <!-- EMPLOYEE -->
                            <td data-label="الموظف">
                                <span class="fw-bold">@item.Employee</span>
                            </td>

                            <!-- MANAGER -->
                           @*  <td data-label="المدير">
                                <span class="text-muted">@item.Manager</span>
                            </td> *@

                            <!-- TYPE -->
                            <td data-label="نوع الطلب">
                                <span class="badge bg-primary px-3 py-2">
                                    @item.RequestType
                                </span>
                            </td>

                            <!-- FROM -->
                            <td data-label="من">
                                @item.FromDate.ToString("yyyy-MM-dd")
                            </td>

                            <!-- TO -->
                            <td data-label="إلى">
                                @item.ToDate.ToString("yyyy-MM-dd")
                            </td>

                            <!-- CREATED -->
                            <td data-label="تاريخ الإنشاء">
                                @item.CreatedDate.ToString("yyyy-MM-dd")
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>
@section Scripts
{
    <script>

        function deleteRequest(id) {
            Swal.fire({

                title: 'تأكيد الحذف',
                text: 'هل تريد حذف الطلب؟',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'حذف',
                cancelButtonText: 'إلغاء',
                confirmButtonColor: '#dc3545'

            }).then((result) => {

                if (result.isConfirmed) {
                    $.ajax({

                        url: '/Leave/DeleteRequest',
                        type: 'POST',
                        data: { id: id },

                        success: function (res) {
                            if (res.success) {
                                Swal.fire(
                                    'تم',
                                    'تم حذف الطلب',
                                    'success'
                                ).then(() => {

                                    location.reload();

                                });
                            }
                        }

                    });
                }

            });
        }

    </script>
}