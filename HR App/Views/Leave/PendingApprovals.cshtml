@model List<HR_App.ViewModel.PendingRequestVM>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">

    <!-- ================= HEADER ================= -->
    <div class="page-header mb-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>

                <h4 class="fw-bold mb-1">
                    إدارة الطلبات
                </h4>

                <p class="text-muted mb-0">
                    مراجعة واعتماد أو رفض الطلبات
                </p>

            </div>

            <div>

                <span class="badge bg-primary fs-6 px-4 py-3 shadow-sm">
                    @(Model?.Count ?? 0) طلب
                </span>

            </div>

        </div>

    </div>

    <!-- ================= FILTER TABS ================= -->
    <div class="filters-wrapper mb-4">

        <div class="d-flex flex-wrap gap-2">

            <button class="btn btn-primary filter-btn active" data-type="all">
                الكل
            </button>

            <button class="btn btn-outline-primary filter-btn" data-type="1">
                اعتيادي
            </button>

            <button class="btn btn-outline-warning filter-btn" data-type="2">
                عارضة
            </button>

            <button class="btn btn-outline-danger filter-btn" data-type="3">
                مرضي
            </button>

            <button class="btn btn-outline-success filter-btn" data-type="4">
                امتحانات
            </button>

            <button class="btn btn-outline-info filter-btn" data-type="5">
                مأمورية يوم كامل
            </button>

            <button class="btn btn-outline-warning filter-btn" data-type="6">
                مأمورية التشغيل بنسبة
            </button>

            <button class="btn btn-outline-secondary filter-btn" data-type="7">
                بدل راحة
            </button>

        </div>

    </div>

    <!-- ================= BULK ACTIONS ================= -->
    <div class="bulk-actions mb-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div class="d-flex flex-wrap gap-2">

                <button id="approveSelected"
                        class="btn btn-success action-main-btn">

                    <i class="fas fa-check ms-1"></i>
                    موافقة المحدد

                </button>

                <button id="rejectSelected"
                        class="btn btn-danger action-main-btn">

                    <i class="fas fa-times ms-1"></i>
                    رفض المحدد

                </button>

            </div>

            <button id="approveAll"
                    class="btn btn-outline-primary action-main-btn">

                <i class="fas fa-check-double ms-1"></i>
                موافقة الكل

            </button>

        </div>

    </div>

    <!-- ================= TABLE ================= -->
    <div class="report-container">

        <div class="table-responsive">

            <table id="example" class="table-modern">

                <thead>

                    <tr>

                        <th>
                            <input type="checkbox" id="selectAll" />
                        </th>

                        <th>
                            الإجراءات
                        </th>

                        <th>
                            الموظف
                        </th>

                        <th>
                            نوع الطلب
                        </th>

                        <th>
                            من تاريخ
                        </th>

                        <th>
                            إلى تاريخ
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var item in Model)
                        {
                            var badgeClass = item.RequestTypeId switch
                            {
                                1 => "bg-primary",

                                2 => "bg-warning text-dark",

                                3 => "bg-danger",

                                4 => "bg-success",

                                5 => "bg-info text-dark",

                                6 => "bg-warning text-dark",

                                7 => "bg-secondary",

                                _ => "bg-light text-dark"
                            };

                            <tr data-type="@item.RequestTypeId">

                                <!-- CHECKBOX -->
                                <td data-label="تحديد">

                                    <input type="checkbox"
                                           class="row-check"
                                           data-app="@item.ApprovalId" />

                                </td>

                                <!-- ACTIONS -->
                                <td data-label="الإجراءات">

                                    <div class="d-flex justify-content-center gap-2">

                                        <!-- APPROVE -->
                                        <button onclick="respond(@item.ApprovalId, @item.RequestId, 2)"
                                                class="btn btn-success btn-sm action-btn">

                                            <i class="fas fa-check-circle"></i>

                                        </button>

                                        <!-- REJECT -->
                                        <button onclick="respond(@item.ApprovalId, @item.RequestId, 3)"
                                                class="btn btn-danger btn-sm action-btn">

                                            <i class="fas fa-times-circle"></i>

                                        </button>

                                    </div>

                                </td>

                                <!-- EMPLOYEE -->
                                <td data-label="الموظف">

                                    <span class="fw-bold">
                                        @item.EmployeeName
                                    </span>

                                </td>

                                <!-- TYPE -->
                                <td data-label="نوع الطلب">

                                    <span class="badge @badgeClass px-3 py-2">
                                        @item.RequestType
                                    </span>

                                </td>

                                <!-- FROM -->
                                <td data-label="من تاريخ">

                                    @item.FromDate.ToString("yyyy-MM-dd")

                                </td>

                                <!-- TO -->
                                <td data-label="إلى تاريخ">

                                    @item.ToDate.ToString("yyyy-MM-dd")

                                </td>

                            </tr>
                        }
                    }
                   


                </tbody>

            </table>

        </div>

    </div>

</div>
@section Scripts
{
    <script>

        $(document).ready(function () {

            // =========================
            // GLOBAL STATE
            // =========================
            let selectedIds = [];

            var table = $('#example').DataTable();

            window.currentFilter = 'all';

            // =========================
            // DATATABLE FILTER
            // =========================
            $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {

                let row = table.row(dataIndex).node();

                let rowType = $(row).attr('data-type');

                if (window.currentFilter === 'all')
                    return true;

                return rowType === window.currentFilter;

            });

            // =========================
            // FILTER BUTTONS
            // =========================
            $('.filter-btn').on('click', function () {

                $('.filter-btn')
                    .removeClass('active btn-primary')
                    .addClass('btn-outline-primary');

                $(this)
                    .removeClass('btn-outline-primary')
                    .addClass('btn-primary active');

                window.currentFilter = $(this).attr('data-type');

                table.page('first').draw(false);

            });

            // =========================
            // CHECKBOX CHANGE
            // =========================
            $(document).on('change', '.row-check', function () {

                let id = parseInt($(this).data('app'));

                if ($(this).is(':checked')) {

                    if (!selectedIds.includes(id)) {
                        selectedIds.push(id);
                    }

                } else {

                    selectedIds = selectedIds.filter(x => x !== id);

                }

                console.log("selectedIds:", selectedIds);

            });

            // =========================
            // SELECT ALL
            // =========================
            $('#selectAll').on('change', function () {

                let checked = $(this).is(':checked');

                // لو uncheck فضي الليست مرة واحدة
                if (!checked) {
                    selectedIds = [];
                }

                table.$('.row-check').each(function () {

                    let id = parseInt($(this).data('app'));

                    $(this).prop('checked', checked);

                    if (checked) {

                        if (!selectedIds.includes(id)) {
                            selectedIds.push(id);
                        }

                    }

                });

                console.log("selectedIds:", selectedIds);

            });

            // =========================
            // KEEP CHECKBOX STATE AFTER DRAW
            // =========================
            table.on('draw', function () {

                $('.row-check').each(function () {

                    let id = parseInt($(this).data('app'));

                    if (selectedIds.includes(id)) {

                        $(this).prop('checked', true);

                    } else {

                        $(this).prop('checked', false);

                    }

                });

            });

            // =========================
            // BULK PROCESS
            // =========================
            function processBulk(status, all = false) {

                let selected = [];

                if (all) {

                    selected = table.$('.row-check').map(function () {

                        return parseInt($(this).data('app'));

                    }).get();

                } else {

                    // استخدم الـ state المحفوظة
                    selected = [...selectedIds];

                }

                console.log("Selected:", selected);

                if (selected.length === 0) {

                    Swal.fire(
                        'تنبيه',
                        'لم يتم اختيار أي طلب',
                        'warning'
                    );

                    return;
                }

                let actionText = status == 2 ? "موافقة" : "رفض";

                let actionColor = status == 2
                    ? "#198754"
                    : "#dc3545";

                Swal.fire({

                    title: 'تأكيد',

                    html: `هل تريد <b>${actionText}</b> عدد <b>${selected.length}</b> طلب؟`,

                    icon: 'question',

                    showCancelButton: true,

                    confirmButtonText: actionText,

                    cancelButtonText: 'إلغاء',

                    confirmButtonColor: actionColor,

                    showLoaderOnConfirm: true,

                    preConfirm: () => {

                        return $.ajax({

                            url: '/Leave/ProcessApprovalBulk',

                            type: 'POST',

                            contentType: 'application/json',

                            data: JSON.stringify({

                                approvalIds: selected,

                                status: status,

                                notes: ''

                            })

                        })
                        .then(res => {

                            if (!res.success) {

                                throw new Error(
                                    res.message || 'حدث خطأ'
                                );

                            }

                            return res;

                        })
                        .catch(err => {

                            Swal.showValidationMessage(
                                err.message
                            );

                        });

                    }

                }).then((result) => {

                    if (result.isConfirmed) {

                        Swal.fire({

                            icon: 'success',

                            title: 'تم بنجاح',

                            text: `تم تنفيذ العملية على ${result.value.count} طلب`,

                            confirmButtonText: 'حسناً'

                        }).then(() => {

                            location.reload();

                        });

                    }

                });

            }

            // =========================
            // BUTTON EVENTS
            // =========================
            $('#approveSelected').click(function () {

                processBulk(2);

            });

            $('#rejectSelected').click(function () {

                processBulk(3);

            });

            $('#approveAll').click(function () {

                processBulk(2, true);

            });

            // =========================
            // SINGLE APPROVAL
            // =========================
            window.respond = function (appId, reqId, status) {

                let actionText = status == 2
                    ? "موافقة"
                    : "رفض";

                let actionColor = status == 2
                    ? "#198754"
                    : "#dc3545";

                Swal.fire({

                    title: 'هل أنت متأكد؟',

                    text: 'سيتم تنفيذ الإجراء على الطلب',

                    icon: 'question',

                    input: 'textarea',

                    inputPlaceholder: 'أضف ملاحظاتك هنا...',

                    showCancelButton: true,

                    confirmButtonText: actionText,

                    cancelButtonText: 'إلغاء',

                    confirmButtonColor: actionColor,

                    reverseButtons: true,

                    showLoaderOnConfirm: true,

                    preConfirm: (notes) => {

                        return $.ajax({

                            url: '/Leave/ProcessApprovalBulk',

                            type: 'POST',

                            contentType: 'application/json',

                            data: JSON.stringify({

                                approvalIds: [appId],

                                status: status,

                                notes: notes

                            })

                        })
                        .then(res => {

                            if (!res.success) {

                                throw new Error(
                                    res.message || 'حدث خطأ'
                                );

                            }

                            return res;

                        })
                        .catch(err => {

                            Swal.showValidationMessage(
                                err.message
                            );

                        });

                    }

                }).then((result) => {

                    if (result.isConfirmed) {

                        Swal.fire({

                            icon: 'success',

                            title: 'تم بنجاح',

                            text: 'تم معالجة الطلب بنجاح',

                            confirmButtonText: 'حسناً'

                        }).then(() => {

                            location.reload();

                        });

                    }

                });

            };

        });

    </script>
}