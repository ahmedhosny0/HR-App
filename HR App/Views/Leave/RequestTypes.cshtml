@model List<HR_App.ViewModel.RequestTypeVM>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" type="text/css" href="/css/components.css" />
<link rel="stylesheet" type="text/css" href="/css/report.css" />
<link rel="stylesheet" type="text/css" href="/css/base.css" />
<link href="/css/lib/bootstrap.min.css" rel="stylesheet">
<link href="/css/lib/select2.min.css" rel="stylesheet" />

<style>
    .page-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
    }

    .page-header {
        background: linear-gradient(135deg, #0d6efd, #0b5ed7);
        padding: 18px;
    }

        .page-header h5 {
            margin: 0;
            font-weight: 700;
            color: #fff;
        }

    .form-control,
    .form-select {
        border-radius: 12px;
        min-height: 45px;
        border: 1px solid #dbe2ea;
    }

        .form-control:focus,
        .form-select:focus {
            box-shadow: 0 0 0 0.15rem rgba(13,110,253,.15);
            border-color: #86b7fe;
        }

    .btn-save {
        border-radius: 12px;
        height: 48px;
        font-weight: 700;
        font-size: 15px;
    }

    .table-modern {
        vertical-align: middle;
        margin-bottom: 0;
    }

        .table-modern thead {
            background: #f8f9fa;
        }

        .table-modern th {
            font-weight: 700;
            border-bottom-width: 1px;
            white-space: nowrap;
        }

    .badge-custom {
        background: rgba(13,110,253,.1);
        color: #0d6efd;
        padding: 6px 12px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 700;
    }

    .empty-state {
        text-align: center;
        padding: 30px;
        color: #777;
    }
</style>

<div class="container mt-5" style="direction:rtl">

    <!-- إضافة نوع الطلب -->
    <div class="card shadow-sm page-card mb-4">

        <div class="page-header">
            <h5>
                <i class="bi bi-plus-circle-fill me-2"></i>
                إضافة نوع طلب جديد
            </h5>
        </div>

        <div class="card-body p-4">

            <form method="post" action="/Leave/AddRequestType">

                <div class="mb-4">
                    <label class="form-label fw-bold mb-2">
                        اسم نوع الطلب
                    </label>

                    <input type="text"
                           name="Name"
                           class="form-control"
                           placeholder="مثال: إجازة / مأمورية / إضافي"
                           required />
                </div>

                <div class="d-grid">
                    <button class="btn btn-success btn-save shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        حفظ النوع
                    </button>
                </div>

            </form>

        </div>

    </div>

    <!-- جدول الأنواع -->
    <div class="card shadow-sm page-card">

        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-list-ul me-2"></i>
                أنواع الطلبات
            </h5>
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover table-modern text-center">

                    <thead>
                        <tr>
                            <th style="width:80px">#</th>
                            <th>اسم النوع</th>
                            <th style="width:180px">الحالة</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.RequestTypeId</strong>
                                    </td>

                                    <td class="fw-bold">
                                        @item.Name
                                    </td>

                                    <td>
                                        <span class="badge-custom">
                                            مفعل
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3">

                                    <div class="empty-state">
                                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                        لا توجد أنواع طلبات مضافة حالياً
                                    </div>

                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<script src="/js/lib/jquery-3.6.0.min.js"></script>
<script src="/js/lib/sweetalert2@11.js"></script>

@if (TempData["SuccessMessage"] != null)
{
    <script>
        Swal.fire({
            icon: 'success',
            title: 'تم بنجاح',
            text: '@TempData["SuccessMessage"]',
            confirmButtonText: 'حسناً'
        });
    </script>
}