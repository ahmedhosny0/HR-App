@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CK Evaluation System</title>

    <link href="/css/lib/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/lib/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/lib/bootstrap.min.css">
    <link href="/css/site.css" rel="stylesheet">
</head>

<body>

    <div class="container-main">

        <!-- LEFT -->
        <div class="left-side">
            <div class="brand">Circle K</div>
            <div class="subtitle">Branch Evaluation System</div>

            <div class="features">
                ✔ Track branch performance<br>
                ✔ Real-time analytics<br>
                ✔ KPI & scoring system
            </div>
        </div>

        <!-- RIGHT -->
        <div class="right-side">
            <div class="login-box">

                <div class="login-title">Welcome Back 👋</div>

                @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
                {
                    <div class="alert alert-danger text-center">@ViewBag.ErrorMessage</div>
                }

                <form method="post"  id="loginForm">

                    <!-- Username -->
                    <div class="mb-3 input-group-custom">
                        <i class="bi bi-person"></i>
                        <input type="text" name="username" autocomplete="username" class="form-control" placeholder="Username" value="@ViewBag.SavedUsername" required>
                    </div>

                    <!-- Password -->
                    <div class="mb-2 input-group-custom password-group">
                        <i class="bi bi-lock"></i>

                        <input type="password" id="passwordInput" autocomplete="current-password" name="password"
                               class="form-control" placeholder="Password" required>

                        <span class="toggle-password" onclick="togglePassword()">
                            <i class="bi bi-eye"></i>
                        </span>
                    </div>

                    <!-- Options -->
                    <div class="d-flex justify-content-between align-items-center mb-3 small">
                        <div>
                            <input type="checkbox" id="remember" name="rememberMe"
                                   @((ViewBag.RememberMe != null && (bool)ViewBag.RememberMe) ? "checked" : "") value="true">
                            <label for="remember"> Remember me</label>
                        </div>

                        <a href="javascript:void(0)" onclick="openForgotModal()" class="text-decoration-none" style="color:#ff3b3b;">
                            استعادة كلمة المرور?
                        </a>
                    </div>

                    <!-- Button -->
                    <button type="submit" class="btn btn-login w-100" id="loginBtn">
                        Login
                    </button>

                </form>

                <div class="footer-text">
                    © Circle K Evaluation Platform
                </div>

            </div>
        </div>

    </div>
    <div class="modal fade" id="forgotModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content forgot-box">

                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fa fa-unlock-alt"></i> استعادة كلمة المرور
                    </h5>
                    <button type="button" class="btn-close" onclick="closeForgotModal()"></button>
                </div>

                <div class="modal-body text-center">
                    <p class="text-muted">
                        أدخل بريدك الإلكتروني المسجل لدينا وسنرسل لك بيانات الدخول
                    </p>

                    <input type="email"
                           id="forgotEmail"
                           class="form-control text-center"
                           placeholder="example@mail.com" />
                </div>

                <div class="modal-footer justify-content-center">
                    <button class="btn btn-secondary" onclick="closeForgotModal()">إلغاء</button>
                    <button class="btn btn-danger" onclick="sendForgot()">
                        <i class="fa fa-paper-plane"></i> إرسال
                    </button>
                </div>

            </div>
        </div>
    </div>
    <script src="/js/lib/jquery-3.6.0.min.js"></script>
    <script src="/js/lib/sweetalert2@11.js"></script>
    <script src="~/js/site.js"></script>
    <script src="/js/lib/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
                  var Usererror = "@Html.Raw(ViewBag.Usererror ?? "")";
        var Emptydata = "@Html.Raw(ViewBag.Emptydata ?? "")";
        var u = "@Html.Raw(ViewBag.u ?? "")";

            console.log("Usererror is: [" + Usererror + "]");
            console.log("Emptydata is: [" + Emptydata + "]");

            if (Usererror === "V") {
                Swal.fire({
                    icon: "error",
                    title: "Wrong Data",
                    text: "خطأ في إسم المستخدم أو كلمة السر",
                    timer: 5500
                });
            } else if (Emptydata === "V") {
                Swal.fire({
                    icon: "error",
                    title: "Oops...",
                    text: "Please input your Username and Password!",
                    timer: 5500
                });
            }

            if (u === "u") {
                Swal.fire({
                    title: "لقد تم تغيير كلمة السر بنجاح",
                    text: "سجل بكلمة السر الجديده",
                    icon: "success",
                    timer: 6500
                });
            }
        });
    </script>
    <script>
        // فتح الـ Modal
        function openForgotModal() {
            var myModal = new bootstrap.Modal(document.getElementById('forgotModal'), {
                keyboard: false
            });
            myModal.show();
        }

        // إغلاق الـ Modal
        function closeForgotModal() {
            var myModal = bootstrap.Modal.getInstance(document.getElementById('forgotModal'));
            myModal.hide();
        }

        // إرسال البريد الإلكتروني لاستعادة كلمة المرور
        function sendForgot() {
            var email = $('#forgotEmail').val().trim();

            var emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

            if (!email) {
                Swal.fire("خطأ", "من فضلك أدخل البريد الإلكتروني", "error");
                return;
            }

            if (!emailPattern.test(email)) {
                Swal.fire("خطأ", "صيغة الإيميل غير صحيحة", "error");
                return;
            }

            Swal.fire({
                title: 'جاري الإرسال...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            $.ajax({
                url: '/Login/ForgotPassword',
                type: 'POST',
                data: { email: email },
                        success: function (res) {
            Swal.close();

            if (res.success) {
                Swal.fire("تم", res.message, "success");
            } else {
                Swal.fire("خطأ", res.message, "error");
            }
        },
                error: function () {
                    Swal.close();
                    Swal.fire("خطأ", "فشل الإرسال", "error");
                }
            });
        }
    </script>    <!-- JS داخلي -->
    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            const icon = document.querySelector(".toggle-password i");

            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            }
        }

        // Loading Button
        document.getElementById("loginForm").addEventListener("submit", function () {
            const btn = document.getElementById("loginBtn");
            btn.innerHTML = `<span class="spinner-border spinner-border-sm"></span> Logging...`;
            btn.disabled = true;
        });
    </script>

</body>
</html>