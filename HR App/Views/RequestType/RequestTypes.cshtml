@model List<HR_App.ViewModel.RequestTypeVM>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container mt-4">

    <!-- إضافة نوع الطلب -->
    <div class="card shadow-sm page-card mb-4">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-people-fill me-2"></i>
                إضافة نوع طلب جديد
            </h5>
        </div>


        <div class="card-body p-4">

            <form method="post" action="/RequestType/AddRequestType">

                <div class="mb-4">
                    <label class="form-label fw-bold mb-2">
                        اسم نوع الطلب
                    </label>

                    <input type="text"
                           name="Name"
                           class="form-control"
                           placeholder="مثال: إجازة / مأمورية / إضافي"
                           required />
                </div>

                <div class="d-grid">
                    <button class="btn btn-success btn-save shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        حفظ النوع
                    </button>
                </div>

            </form>

        </div>

    </div>

    <!-- جدول الأنواع -->
    <div class="card shadow-sm page-card">

        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-list-ul me-2"></i>
                أنواع الطلبات
            </h5>
        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table id="example" class="table table-hover table-modern text-center">
                    <thead>
                        <tr>
                            <th style="width:80px">#</th>
                            <th>اسم النوع</th>
                            <th style="width:180px">الحالة</th>
                            <th >الإجراء</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.RequestTypeId</strong>
                                    </td>

                                    <td class="fw-bold">
                                        @item.Name
                                    </td>

                                    <td>
                                        <span class="badge-custom">
                                            مفعل
                                        </span>
                                    </td>
                                    <td>
                                        <a href="/RequestType/EditRequestType?id=@item.RequestTypeId"
                                           class="btn btn-sm btn-primary">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        <a href="/RequestType/DeleteRequestType?id=@item.RequestTypeId"
                                           class="btn btn-sm btn-danger"
                                           onclick="return confirm('هل أنت متأكد من الحذف؟')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3">

                                    <div class="empty-state">
                                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                        لا توجد أنواع طلبات مضافة حالياً
                                    </div>

                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

@section Scripts
{

    </script>
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'تم بنجاح',
                html: '@TempData["SuccessMessage"]',
                confirmButtonText: 'حسناً'
            });
        </script>
    }
}
